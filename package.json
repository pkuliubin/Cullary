{
  "name": "cullary-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:runtime": "tauri build --config src-tauri/tauri.bundle-runtime.conf.json",
    "check:mock": "node app/scripts/validate-mock-data.mjs",
    "check:desktop": "npm run check:mock && npm run test:review-state && npm run test:staging-contract && npm run build && npm run test:render",
    "test:review-state": "node app/scripts/test-review-state.mjs",
    "test:staging-contract": "node app/scripts/test-staging-contract.mjs",
    "test:render": "node app/scripts/test-built-ui.mjs",
    "runtime:stage": "python3 scripts/package_runtime.py --output build/cullary-runtime-with-python --python-env /opt/anaconda3/envs/cullary",
    "runtime:build:app": "tauri build --debug --bundles app --config src-tauri/tauri.bundle-runtime.conf.json",
    "runtime:smoke": "python3 scripts/smoke_app_runtime.py --app \"src-tauri/target/debug/bundle/macos/Cullary Runtime.app\" --folder /Users/liubin/Desktop/TestImage",
    "runtime:smoke:full": "python3 scripts/smoke_app_runtime.py --app \"src-tauri/target/debug/bundle/macos/Cullary Runtime.app\" --folder /Users/liubin/Desktop/TestImage --full --sample --force --limit 4 --timeout 900",
    "runtime:verify": "npm run runtime:stage && npm run runtime:build:app && npm run runtime:smoke && npm run runtime:smoke:full",
    "runtime:build:release": "npm run runtime:build:release:app && npm run runtime:dmg:internal",
    "runtime:smoke:release": "python3 scripts/smoke_app_runtime.py --app \"src-tauri/target/release/bundle/macos/Cullary Runtime.app\" --folder /Users/liubin/Desktop/TestImage",
    "runtime:verify:release": "npm run runtime:stage && npm run runtime:build:release && npm run runtime:smoke:release && npm run runtime:smoke:dmg && npm run runtime:summary",
    "runtime:build:release:app": "tauri build --bundles app,dmg --config src-tauri/tauri.bundle-runtime.conf.json",
    "runtime:dmg:internal": "scripts/build_internal_runtime_dmg.sh",
    "runtime:smoke:dmg": "python3 scripts/verify_internal_runtime_dmg.py --folder /Users/liubin/Desktop/TestImage",
    "runtime:summary": "python3 scripts/write_release_summary.py"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
